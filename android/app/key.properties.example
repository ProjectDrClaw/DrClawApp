# 复制本文件为 key.properties 后填写（key.properties 与 *.jks 均勿提交）
#
# 生成示例：
# keytool -genkeypair -v -keystore drclaw-release.jks -alias drclaw \
#   -keyalg RSA -keysize 2048 -validity 36500 \
#   -dname "CN=Dr.Claw, OU=Mobile, O=Dr.Claw, C=CN"
#
storePassword=your-store-password
keyPassword=your-key-password
keyAlias=drclaw
storeFile=drclaw-release.jks
