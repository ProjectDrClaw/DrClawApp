# 复制为 key.properties 后填写（key.properties 与 *.jks 均勿提交）
#
# 生成正式证书示例：
# keytool -genkeypair -v -storetype PKCS12 -keystore drclaw.jks -alias drclaw \
#   -keyalg RSA -keysize 2048 -validity 36500 \
#   -dname "CN=Dr.Claw, OU=Mobile, O=Dr.Claw, L=Shanghai, ST=Shanghai, C=CN"
#
storePassword=your-store-password
keyPassword=your-key-password
keyAlias=drclaw
storeFile=drclaw.jks
